<h4>Chi tiết đơn hàng</h4>
<table class="table" id="orderItems">
    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>
                @Html.DropDownList("ItemID", null, htmlAttributes: new { @class = "form-control item-select" })
            </td>
            <td>
                <input type="number" name="Quantity" class="form-control quantity-input" value="1" min="1" />
            </td>
            <td><button type="button" class="btn btn-danger remove">Xóa</button></td>
        </tr>
    </tbody>
</table>
<button type="button" id="addItem" class="btn btn-info">Thêm món hàng</button>
<hr />

@section Scripts {
    <script>
        $("#addItem").click(function () {
            var row = $("#orderItems tbody tr:first").clone();
            row.find(".quantity-input").val(1);
            $("#orderItems tbody").append(row);
        });

        $(document).on("click", ".remove", function () {
            if ($("#orderItems tbody tr").length > 1) {
                $(this).closest("tr").remove();
            }
        });
    </script>
}