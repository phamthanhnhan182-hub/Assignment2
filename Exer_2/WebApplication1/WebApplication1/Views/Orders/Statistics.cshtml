@{
    ViewBag.Title = "Thống kê sản phẩm bán chạy";
}

<div class="jumbotron">
    <h2><i class="glyphicon glyphicon-stats"></i> Top 5 Sản Phẩm Bán Chạy Nhất</h2>
    <p class="lead">Dựa trên tổng số lượng đã đặt từ khách hàng.</p>
</div>

<table class="table table-striped table-hover">
    <thead class="thead-dark">
        <tr>
            <th>Tên Sản Phẩm</th>
            <th>Tổng Số Lượng Bán Ra</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in ViewBag.BestItems)
        {
            // Tách chuỗi ra lại thành tên và số lượng
            string[] parts = item.Split('|');
            <tr>
                <td><strong>@parts[0]</strong></td>
                <td>
                    <span class="label label-success">
                        @parts[1]
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="no-print">
    <button onclick="window.print()" class="btn btn-primary">
        <i class="glyphicon glyphicon-print"></i> In báo cáo thống kê
    </button>
</div>